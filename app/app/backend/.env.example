# Variables de entorno para LikeNew Backend
# Copia este archivo a .env y rellena los valores
# IMPORTANTE: Nunca subas el archivo .env al repositorio

# Base de datos (obligatorio en producción)
# Supabase: Project Settings > Database > Connection string > Connection pooling
# Usar modo Transaction, puerto 6543
# Formato: postgresql://postgres.[ref]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
ENVIRONMENT=prod

# Entorno
