# Variables de entorno para LikeNew Backend

# Copia este archivo a .env y rellena los valores

# IMPORTANTE: Nunca subas el archivo .env al repositorio



# Base de datos PostgreSQL (obligatorio en producción)

# El backend usa SQLAlchemy + asyncpg (cualquier Postgres compatible).

#

# DigitalOcean Managed Database (PostgreSQL) — recomendado si la app está en App Platform:

#   En DO: Databases → el cluster → pestaña "Connection details" → copia la URI (usuario suele ser doadmin,

#   puerto 25060, base defaultdb). Si la URI no trae SSL, añade al final: ?sslmode=require

#   Ejemplo de forma (sustituye host y contraseña por los tuyos):

#   postgresql://doadmin:CONTRASEÑA@db-postgresql-nyc3-xxxxx.b.db.ondigitalocean.com:25060/defaultdb?sslmode=require

#

#   En App Platform puedes "vincular" la base de datos al componente backend para que inyecte DATABASE_URL,

#   o pegar la misma URI manualmente como variable secreta del backend.

#

# Local / otro proveedor: añade ?sslmode=require o ?ssl=require si el servidor exige SSL.

#

DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/postgres?sslmode=require

ENVIRONMENT=prod



# Entorno

