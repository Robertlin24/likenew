            "description": "Primary key, auto-increment"
        },
        "user_id": {
            "type": "string",
            "description": "User ID from auth"
        },
        "trash_can_count": {
            "type": "integer",
            "description": "Number of trash cans to clean (1, 2, or 3)"
        },
        "service_price": {
